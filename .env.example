# Application
ENVIRONMENT=development
SECRET_KEY=change_me_in_production_min_32_chars

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (auto-configured via Docker Compose in dev)
DATABASE_URL=postgresql://edgeai:edgeai_secret@localhost:5432/edgeai

# Redis (mot de passe OBLIGATOIRE — Redis ne doit jamais être exposé sans auth)
# Génère un mot de passe fort : openssl rand -hex 32
REDIS_PASSWORD=change_me_openssl_rand_hex_32
# En docker-compose, REDIS_URL est construit automatiquement avec REDIS_PASSWORD.
# Pour usage hors docker, mettre : redis://:LE_PASSWORD@localhost:6379
REDIS_URL=redis://:change_me_openssl_rand_hex_32@localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# Sports Data APIs
FOOTBALL_DATA_API_KEY=your_football_data_key
ODDS_API_KEY=your_odds_api_key

# ML
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Instagram Graph API (publication automatique des value bets)
# Obtenir via : Meta for Developers → ton app → Instagram Basic Display
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
# URL publique de ton API (utilisée pour servir les images à Instagram)
API_BASE_URL=https://edgeai.fr
# Token interne partagé ML pipeline ↔ backend pour déclencher la publication auto
# Génère un secret fort : python -c "import secrets; print(secrets.token_hex(32))"
INSTAGRAM_SERVICE_TOKEN=change_me_generate_with_secrets_token_hex
